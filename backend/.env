# Conexão com o banco PostgreSQL local
PGUSER=postgres
PGHOST=localhost
PGDATABASE=jornada_conexoes
PGPASSWORD=12345678 # senha real do PostgreSQL
PGPORT=5432

# URLs PARA O PRISMA
DATABASE_URL="postgresql://${PGUSER}:${PGPASSWORD}@${PGHOST}:${PGPORT}/${PGDATABASE}?schema=public"


# Chaves JWT para autenticação
JWT_ACCESS_SECRET=sua-chave-secreta-para-o-access-token-curto
JWT_ACCESS_EXPIRATION=15m

JWT_REFRESH_SECRET=sua-chave-secreta-diferente-para-o-refresh-token-longo
JWT_REFRESH_EXPIRATION=30d
