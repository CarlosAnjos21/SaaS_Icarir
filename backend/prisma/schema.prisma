// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuarios {
  id                 Int                  @id @default(autoincrement())
  nome               String               @db.VarChar(100)
  email              String               @unique @db.VarChar(100)
  senha              String               @db.VarChar(255)
  empresa            String?              @db.VarChar(100)
  role               String               @default("user") @db.VarChar(50)
  pontos             Int                  @default(0)
  foto_url           String?              @db.VarChar(255)
  ativo              Boolean              @default(true)
  data_criacao       DateTime             @default(now())
  data_atualizacao   DateTime             @updatedAt
  perfil             Perfis?
  missoes            UsuariosMissoes[]
  tarefas            UsuariosTarefas[]
  respostas_quiz     RespostasQuizzes[]
  cards              UsuariosCards[]
  premiacoes         UsuariosPremiacoes[]
  logs_pontos        LogsPontos[]
  tarefas_validadas  UsuariosTarefas[]    @relation("Validador")
  
  @@map("usuarios")
}

model Perfis {
  id              Int       @id @default(autoincrement())
  usuario_id      Int       @unique
  curiosidades    String?   @db.Text
  linkedin_url    String?   @db.VarChar(255)
  website         String?   @db.VarChar(255)
  interesses      String?   @db.Text
  data_nascimento DateTime? @db.Date
  telefone        String?   @db.VarChar(20)
  data_criacao    DateTime  @default(now())
  data_atualizacao DateTime  @updatedAt
  usuario         Usuarios  @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@map("perfis")
}

model Missoes {
  id                 Int               @id @default(autoincrement())
  titulo             String            @db.VarChar(255)
  descricao          String?           @db.Text
  foto_url           String?           @db.VarChar(255)
  destino            String?           @db.VarChar(255)
  data_inicio        DateTime          @db.Date
  data_fim           DateTime          @db.Date
  preco              Decimal?          @default(0.00) @db.Decimal(8, 2)
  vagas_disponiveis  Int?
  ativo              Boolean           @default(false)
  missao_anterior_id Int?
  data_criacao       DateTime          @default(now())
  data_atualizacao   DateTime          @updatedAt
  tarefas            Tarefas[]
  usuarios           UsuariosMissoes[]

  @@map("missoes")
}

model CategoriasTarefas {
  id        Int       @id @default(autoincrement())
  nome      String    @db.VarChar(100)
  descricao String?   @db.Text
  icone     String?   @db.VarChar(50)
  ordem     Int       @default(0)
  tarefas   Tarefas[]

  @@map("categorias_tarefas")
}

model Tarefas {
  id                 Int               @id @default(autoincrement())
  missao_id          Int
  categoria_id       Int?
  titulo             String            @db.VarChar(255)
  descricao          String?           @db.Text
  instrucoes         String?           @db.Text
  pontos             Int
  tipo               String            @db.VarChar(50)
  dificuldade        String            @db.VarChar(50)
  ativo              Boolean           @default(true)
  ordem              Int               @default(0)
  requisitos         Json?             @db.JsonB
  tarefa_anterior_id Int?
  data_criacao       DateTime          @default(now())
  data_atualizacao   DateTime          @updatedAt
  missao             Missoes           @relation(fields: [missao_id], references: [id], onDelete: Cascade)
  categoria          CategoriasTarefas? @relation(fields: [categoria_id], references: [id])
  quizzes            Quizzes[]
  cards              Cards[]
  usuarios_tarefas   UsuariosTarefas[]
  logs_pontos        LogsPontos[]

  @@map("tarefas")
}

model UsuariosMissoes {
  id                   Int       @id @default(autoincrement())
  usuario_id           Int
  missao_id            Int
  valor_pago           Decimal?  @db.Decimal(8, 2)
  forma_pagamento      String?   @db.VarChar(50)
  status_pagamento     String?   @db.VarChar(50)
  codigo_transacao     String?   @db.VarChar(100)
  data_compra          DateTime? @default(now())
  status_participacao  String?   @db.VarChar(50)
  data_criacao         DateTime  @default(now())
  data_atualizacao     DateTime  @updatedAt
  usuario              Usuarios  @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  missao               Missoes   @relation(fields: [missao_id], references: [id], onDelete: Cascade)
  
  @@unique([usuario_id, missao_id])
  @@map("usuarios_missoes")
}

model UsuariosTarefas {
  id              Int       @id @default(autoincrement())
  usuario_id      Int
  tarefa_id       Int
  concluida       Boolean   @default(false)
  pontos_obtidos  Int       @default(0)
  evidencias      String?   @db.Text
  data_conclusao  DateTime?
  tentativas      Int       @default(0)
  validado_por    Int?
  data_validacao  DateTime?
  data_criacao    DateTime  @default(now())
  data_atualizacao DateTime  @updatedAt
  usuario         Usuarios  @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  tarefa          Tarefas   @relation(fields: [tarefa_id], references: [id], onDelete: Cascade)
  validador       Usuarios? @relation("Validador", fields: [validado_por], references: [id], onDelete: SetNull)

  @@unique([usuario_id, tarefa_id])
  @@map("usuarios_tarefas")
}

model Quizzes {
  id            Int              @id @default(autoincrement())
  tarefa_id     Int?             @unique // Um quiz pode estar ligado a uma única tarefa
  titulo        String           @db.VarChar(255)
  descricao     String?          @db.Text
  imagem_url    String?          @db.VarChar(255)
  empresa_nome  String?          @db.VarChar(100)
  ativo         Boolean          @default(false)
  data_criacao  DateTime         @default(now())
  data_atualizacao DateTime?     @updatedAt
  tarefa        Tarefas?         @relation(fields: [tarefa_id], references: [id], onDelete: SetNull)
  perguntas     PerguntasQuiz[]

  @@map("quizzes")
}

model PerguntasQuiz {
  id            Int                @id @default(autoincrement())
  quiz_id       Int
  enunciado     String             @db.Text
  tipo          String?            @db.VarChar(50)
  opcoes        Json               @db.JsonB // Ex: [{"text": "A", "isCorrect": true}, ...]
  explicacao    String?            @db.Text
  ordem         Int                @default(0)
  data_criacao  DateTime           @default(now())
  data_atualizacao DateTime?       @updatedAt
  quiz          Quizzes            @relation(fields: [quiz_id], references: [id], onDelete: Cascade)
  respostas     RespostasQuizzes[]

  @@map("perguntas_quiz")
}

model RespostasQuizzes {
  id             Int           @id @default(autoincrement())
  usuario_id     Int
  pergunta_id    Int
  resposta       String        @db.Text
  correta        Boolean       @default(false)
  pontos_obtidos Int           @default(0)
  data_resposta  DateTime      @default(now())
  usuario        Usuarios      @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  pergunta       PerguntasQuiz @relation(fields: [pergunta_id], references: [id], onDelete: Cascade)

  @@map("respostas_quizzes")
}

model Cards {
  id            Int             @id @default(autoincrement())
  tarefa_id     Int
  titulo        String          @db.VarChar(150)
  descricao     String?         @db.Text
  ativo         Boolean         @default(true)
  data_criacao  DateTime        @default(now())
  data_atualizacao DateTime?    @updatedAt
  tarefa        Tarefas         @relation(fields: [tarefa_id], references: [id], onDelete: Cascade)
  usuarios_cards UsuariosCards[]

  @@map("cards")
}

model UsuariosCards {
  id                Int       @id @default(autoincrement())
  usuario_id        Int
  card_id           Int
  data_desbloqueio  DateTime  @default(now())
  usuario           Usuarios  @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  card              Cards     @relation(fields: [card_id], references: [id], onDelete: Cascade)

  @@unique([usuario_id, card_id])
  @@map("usuarios_cards")
}

model Premiacoes {
  id                    Int                  @id @default(autoincrement())
  titulo                String               @db.VarChar(255)
  descricao             String?              @db.Text
  tipo                  String               @db.VarChar(50)
  posicao_ranking       Int?
  pontos_necessarios    Int?
  quantidade_disponivel Int?
  imagem_url            String?              @db.VarChar(255)
  ativo                 Boolean              @default(false)
  data_criacao          DateTime             @default(now())
  data_atualizacao      DateTime?            @updatedAt
  usuarios_premiacoes   UsuariosPremiacoes[]

  @@map("premiacoes")
}

model UsuariosPremiacoes {
  id           Int        @id @default(autoincrement())
  usuario_id   Int
  premiacao_id Int
  data_premiacao DateTime @default(now())
  entregue     Boolean    @default(false)
  data_criacao DateTime   @default(now())
  usuario      Usuarios   @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  premiacao    Premiacoes @relation(fields: [premiacao_id], references: [id], onDelete: Cascade)

  @@map("usuarios_premiacoes")
}

model LogsPontos {
  id           Int       @id @default(autoincrement())
  usuario_id   Int
  tarefa_id    Int?
  pontos       Int
  tipo         String    @db.VarChar(50) // "ganho_tarefa", "ganho_quiz", "resgate_premio"
  descricao    String?   @db.Text
  data_criacao DateTime  @default(now())
  usuario      Usuarios  @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  tarefa       Tarefas?  @relation(fields: [tarefa_id], references: [id], onDelete: SetNull)

  @@map("logs_pontos")
}