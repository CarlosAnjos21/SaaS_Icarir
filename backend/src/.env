# .env

# Configuração do Banco de Dados
PGUSER=seu_usuario
PGHOST=seu_host
PGDATABASE=seu_banco_de_dados
PGPASSWORD=sua_senha
PGPORT=5432

# NOVAS CHAVES DE AUTENTICAÇÃO
JWT_ACCESS_SECRET=sua-chave-secreta-para-o-access-token-curto
JWT_ACCESS_EXPIRATION=15m

JWT_REFRESH_SECRET=sua-chave-secreta-diferente-para-o-refresh-token-longo
JWT_REFRESH_EXPIRATION=30d