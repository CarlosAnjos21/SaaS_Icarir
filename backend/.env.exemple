# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Banco de Dados (Supabase) ────────────────────────────────────────────────
# URL com pgbouncer (pooler) — usada pelo Prisma em runtime
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?pgbouncer=true"

# URL direta — usada pelo Prisma para migrations (sem pgbouncer)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL="https://SEU_PROJETO.supabase.co"
SUPABASE_ANON_KEY="sua_anon_key_aqui"
SUPABASE_KEY="sua_service_role_key_aqui"
SUPABASE_BUCKET_PERFIL=images

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=troque_por_secret_forte_aqui
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=troque_por_outro_secret_forte_aqui
JWT_REFRESH_EXPIRATION=30d

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_REGISTRATION_KEY="ChaveSuperSecreta@2026"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Em dev: http://localhost:5173
# Em produção: URL do frontend no Railway/Render/Vercel
ALLOWED_ORIGINS=http://localhost:5173,https://seu-frontend.up.railway.app