// BACKUP of prisma.config.ts - kept because it may contain custom configuration.
// If you need to restore, rename this file back to `prisma.config.ts`.

// The runtime provides `process.env`. Declare a minimal type so TypeScript won't error here
declare const process: { env: { [key: string]: string | undefined } };

// prisma package types may not be available in the project; ignore the module error at build-time
// @ts-ignore
import { defineConfig } from "prisma";

export default defineConfig({
  schema: "prisma/schema.prisma",
  migrations: {
    path: "prisma/migrations",
  },
  engine: "classic",
  datasource: {
    // use process.env for DATABASE_URL to avoid a missing helper import
    url: process.env.DATABASE_URL,
  },
});
